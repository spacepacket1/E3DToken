# ── Ethereum mainnet (source chain) ───────────────────────────────────────────
ETH_RPC_URL=https://mainnet.infura.io/v3/YOUR_INFURA_KEY
ETH_PRIVATE_KEY=0x...
ETH_CHAIN=Ethereum

# ── BNB Smart Chain (destination chain) ───────────────────────────────────────
BSC_RPC_URL=https://bsc-dataseed.binance.org
# Optional: defaults to ETH_PRIVATE_KEY if same wallet controls both chains
BSC_PRIVATE_KEY=0x...
BSC_CHAIN=Bsc

# ── Token addresses ───────────────────────────────────────────────────────────
E3D_TOKEN_ADDRESS=0x6488861b401F427D13B6619C77C297366bCf6386

# ── Transfer config ───────────────────────────────────────────────────────────
# Amount to bridge from Ethereum → BSC per transfer run
TRANSFER_AMOUNT_E3D=100

# BSC address to receive the bridged wrapped E3D (used for check + add-liquidity)
BSC_RECIPIENT_ADDRESS=0x...

# Maps.e3d.ai treasury address on BSC
MAPS_TREASURY_ADDRESS=0x...

# ── Wormhole ──────────────────────────────────────────────────────────────────
WORMHOLE_NETWORK=Mainnet

# ── PancakeSwap liquidity (add-liquidity script) ──────────────────────────────
# Wrapped E3D address on BSC — populated after running 'npm run attest'
WRAPPED_E3D_BSC_ADDRESS=0x...
# BNB amount to pair with E3D in the initial liquidity pool (in BNB, e.g. "0.5")
PANCAKESWAP_BNB_AMOUNT=0.5
# E3D amount to pair with BNB in the initial liquidity pool
PANCAKESWAP_E3D_AMOUNT=50
