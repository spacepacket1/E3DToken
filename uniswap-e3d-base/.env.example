# RPC
BASE_RPC_URL=https://mainnet.base.org

# Wallet (same key used for Wormhole bridging)
BASE_PRIVATE_KEY=

# Token addresses (defaults are already set in config.ts)
WRAPPED_E3D_BASE_ADDRESS=0xDFC9E32Dd0542D12c08ED15FEfadBAe8071B48A5
WETH_BASE_ADDRESS=0x4200000000000000000000000000000000000006

# Initial price: how many E3D = 1 WETH
# e.g. 10000 means 1 WETH = 10,000 E3D
INITIAL_PRICE_E3D_PER_WETH=10000

# Liquidity to seed (used by add-liquidity)
E3D_LIQUIDITY_AMOUNT=50
WETH_LIQUIDITY_AMOUNT=0.005

# Set after running create-pool
POOL_ADDRESS=
