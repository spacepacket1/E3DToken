# ── Ethereum mainnet (source chain) ───────────────────────────────────────────
ETH_RPC_URL=https://mainnet.infura.io/v3/YOUR_INFURA_KEY
ETH_PRIVATE_KEY=0x...
ETH_CHAIN=Ethereum

# ── Base L2 (destination chain) ───────────────────────────────────────────────
BASE_RPC_URL=https://mainnet.base.org
# Optional: defaults to ETH_PRIVATE_KEY if same wallet controls both chains
BASE_PRIVATE_KEY=0x...
BASE_CHAIN=Base

# ── Token addresses ───────────────────────────────────────────────────────────
E3D_TOKEN_ADDRESS=0x6488861b401F427D13B6619C77C297366bCf6386

# ── Transfer config ───────────────────────────────────────────────────────────
# Amount to bridge from Ethereum → Base per transfer run
TRANSFER_AMOUNT_E3D=100

# Base address to receive the bridged wrapped E3D
BASE_RECIPIENT_ADDRESS=0x...

# Maps.e3d.ai treasury address on Base (collects per-call payments)
MAPS_TREASURY_ADDRESS=0x...

# ── Wormhole ──────────────────────────────────────────────────────────────────
WORMHOLE_NETWORK=Mainnet
